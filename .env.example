# Copy to .env and fill in values. Never commit .env to git.

# Databricks workspace
DATABRICKS_HOST=https://adb-xxxxxxxxxxxx.azuredatabricks.net
DATABRICKS_TOKEN=dapi...

# SQL Warehouse HTTP path (Databricks → SQL Warehouses → your warehouse → Connection Details)
DATABRICKS_SQL_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx

# Mapbox public token (mapbox.com → Account → Tokens)
MAPBOX_TOKEN=pk.eyJ1...

# Google OAuth — required to enable login
# Google Cloud Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
# Add https://{your-domain}/auth/callback as an authorized redirect URI
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_WORKSPACE_DOMAIN=surusenterprises.com
APP_URL=https://your-app-domain.com
# Required — app will not start without this. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=daliaesvakmpa!!

# Optional
QUERY_CACHE_SECONDS=300
DASH_DEBUG=false
